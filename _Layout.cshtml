<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-lg" style="background-color: #1a2b23; width: 100%; z-index: 10; padding: 15px 0;">
        <div class="container-fluid px-4">

            <button class="navbar-toggler d-lg-none border-0 bg-transparent text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- CỤM BÊN TRÁI (Thay thế Application Name bằng Home, About, Contact) -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "nav-link text-white fw-medium mx-2" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "nav-link text-white fw-medium mx-2" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "nav-link text-white fw-medium mx-2" })
                    </li>
                </ul>

                <!-- CỤM Ở GIỮA -->
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link text-white fw-medium mx-2" href="#">Destinations</a></li>
                    <li class="nav-item"><a class="nav-link text-white fw-medium mx-2" href="#">Experiences</a></li>
                    <li class="nav-item"><a class="nav-link text-white fw-medium mx-2" href="#">About</a></li>
                </ul>

                <!-- CỤM BÊN PHẢI -->
                <div class="d-flex align-items-center ms-auto flex-nowrap">
                    <a href="#" class="text-white me-4 fs-5" style="text-decoration:none;">🔍</a> <!-- Tạm dùng icon emoji hoặc bạn chèn link icon bootstrap -->
                    <button class="btn text-white text-nowrap fw-semibold" style="background-color: #2d4a38; padding: 8px 20px;">Book Now</button>
                </div>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
